# =============================================================================
# .gitignore for the paperclip-greeteat deployment-spec repository
# =============================================================================
# This repo holds the GreetEat Paperclip GCP deployment configuration
# (Terraform modules, Dockerfile, scripts, GitHub Actions workflows).
# It deploys an external open-source application; it does NOT contain the
# Paperclip application source code itself.

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride

# -----------------------------------------------------------------------------
# Editors / IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# -----------------------------------------------------------------------------
# Obsidian (note-taking app metadata, not project files)
# -----------------------------------------------------------------------------
.obsidian/

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------
# Local .terraform directories (provider plugins, modules cache)
**/.terraform/
**/.terraform.tfstate.lock.info

# Plan output (generated by `terraform plan -out=plan.tfplan`)
*.tfplan
*.tfplan.*

# Crash logs
crash.log
crash.*.log

# State files (we use a remote GCS backend, but ignore any that escape locally)
*.tfstate
*.tfstate.*

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# DO NOT IGNORE:
#   .terraform.lock.hcl   (commit provider lockfile)
#   *.tfvars              (committed; pinned env-specific values, no secrets)
#   versions.tfvars       (committed; pinned paperclip version + image digest)

# -----------------------------------------------------------------------------
# Local secrets / credentials — NEVER commit
# -----------------------------------------------------------------------------
*.local
.env
.env.*
!.env.example
# /secrets/ — anchored to repo root ONLY, so it doesn't accidentally match
# infra/modules/secrets/ (the Terraform module that manages Secret Manager
# IAM bindings, which is a code module we DO commit). For nested credential
# dirs, use the *.key / *.pem / gcp-key*.json patterns below.
/secrets/
*.key
*.pem
gcp-key*.json
service-account*.json
application_default_credentials.json
*.tfvars.local
